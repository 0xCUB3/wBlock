<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>wBlock Advanced</string>
	<key>NSExtension</key>
	<dict>
		<key>NSExtensionPointIdentifier</key>
		<string>com.apple.Safari.web-extension</string>
		<key>NSExtensionPrincipalClass</key>
		<string>$(PRODUCT_MODULE_NAME).SafariWebExtensionHandler</string>
		<key>SFSafariAssociatedContentBlockers</key>
		<array>
			<string>skula.wBlock.wBlock-Ads</string>
			<string>skula.wBlock.wBlock-Privacy</string>
			<string>skula.wBlock.wBlock-Security</string>
			<string>skula.wBlock.wBlock-Custom</string>
			<string>skula.wBlock.wBlock-Foreign</string>
		</array>
	</dict>
	<key>NSHumanReadableDescription</key>
	<string>Advanced extension for enhanced filtering capabilities and website compatibility fixes.</string>
</dict>
</plist>
